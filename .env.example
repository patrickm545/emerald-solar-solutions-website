# Admin protection for protected routes such as /admin and installer review flows.
ADMIN_USERNAME=change-me
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional secure webhook target for contact form delivery.
# If left blank, submissions are written to storage/contact-requests.jsonl
# on the server and never exposed from /public.
CONTACT_FORM_WEBHOOK_URL=
CONTACT_FORM_WEBHOOK_BEARER_TOKEN=
